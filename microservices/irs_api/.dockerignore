# Docker ignore file for IRS API
# Ignore files that shouldn't be in Docker image

# Virtual environments
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Models (will be mounted as volume)
models/*.pkl
models/*.joblib

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
!README.md

# Tests
tests/
.pytest_cache/

# Logs
*.log

# Environment
.env
!.env.example
